generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  role         String   @default("AGENT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  leads      Lead[]
  properties Property[]
  aiRecords  AIRecord[]
}

model Property {
  id           String   @id @default(uuid())
  title        String
  description  String?
  price        Float?
  location     String?
  propertyType String? // Rent, Sale, etc.
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  leads Lead[]
}

enum LeadStatus {
  NEW
  FOLLOW_UP
  VISITING
  CLOSED
}

model Lead {
  id             String     @id @default(uuid())
  name           String
  phone          String?
  platformSource String? // TikTok, Telegram, Direct, etc.
  status         LeadStatus @default(NEW)
  budget         Float?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id])
}

model AIRecord {
  id         String   @id @default(uuid())
  prompt     String
  response   String
  actionType String // Caption, Reply
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
